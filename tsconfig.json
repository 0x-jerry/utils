{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": [
      "DOM",
      "ESNext"
    ],
    "skipDefaultLibCheck": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src",
    "env.d.ts"
  ]
}