  },
  "release": {
    "clean": [
      "dist"
    ]
  },
  "devDependencies": {
    "@0x-jerry/x-release": "^3.0.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "happy-dom": "^20.8.4",
    "memfs": "^4.56.11",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "nanoid": "^5.1.7",
    "picocolors": "^1.1.1"
